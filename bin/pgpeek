#!/usr/bin/env bash
set -e

PGPEEK_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PGPEEK_DIR"

# Check if node_modules exists
if [ ! -d "node_modules" ]; then
  echo "Installing dependencies..."
  pnpm install --frozen-lockfile 2>/dev/null || npm install
fi

# Build if .next doesn't exist
if [ ! -d ".next" ]; then
  echo "Building pgpeek..."
  pnpm build 2>/dev/null || npm run build
fi

# Find an available port starting from PORT or 3000
PORT="${PORT:-3000}"
while lsof -i :"$PORT" >/dev/null 2>&1; do
  PORT=$((PORT + 1))
done

echo "Starting pgpeek on http://localhost:$PORT"
echo "Press Ctrl+C to stop"

# Open browser after a short delay
(sleep 2 && open "http://localhost:$PORT" 2>/dev/null || true) &

pnpm start -p "$PORT" 2>/dev/null || npm start -- -p "$PORT"
